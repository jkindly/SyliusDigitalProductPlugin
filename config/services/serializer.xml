<?xml version="1.0" encoding="UTF-8" ?>

<container
    xmlns="http://symfony.com/schema/dic/services"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd"
>
    <services>
        <service id="sylius_digital_product_plugin.serializer.registry" class="SyliusDigitalProductPlugin\Serializer\FileConfigurationSerializerRegistry">
            <argument type="tagged_iterator" tag="sylius_digital_product_plugin.file_configuration_serializer" index-by="key"/>
        </service>

        <service id="sylius_digital_product_plugin.serializer.uploaded_digital_file_configuration"
                 class="SyliusDigitalProductPlugin\Serializer\FileConfigurationSerializer"
        >
            <argument type="service" id="serializer"/>
            <argument>SyliusDigitalProductPlugin\Dto\UploadedFileDto</argument>
            <tag name="sylius_digital_product_plugin.file_configuration_serializer" key="%sylius_digital_product_plugin.file_type.uploaded%"/>
        </service>

        <service id="sylius_digital_product_plugin.serializer.external_url_digital_file_configuration"
                 class="SyliusDigitalProductPlugin\Serializer\FileConfigurationSerializer"
        >
            <argument type="service" id="serializer"/>
            <argument>SyliusDigitalProductPlugin\Dto\ExternalUrlFileDto</argument>
            <tag name="sylius_digital_product_plugin.file_configuration_serializer" key="%sylius_digital_product_plugin.file_type.external_url%"/>
        </service>

        <service id="sylius_digital_product_plugin.serializer.digital_product_denormalizer" class="SyliusDigitalProductPlugin\Serializer\DigitalProductDenormalizer">
            <argument type="service" id="api_platform.symfony.iri_converter"/>
            <argument type="service" id="sylius_digital_product_plugin.handler.uploaded_digital_file"/>
            <argument type="service" id="sylius_digital_product_plugin.factory.chunked_uploaded_file"/>
            <argument type="service" id="sylius_digital_product_plugin.uploader.chunked_upload_handler"/>
            <argument>%sylius_digital_product_plugin.file_type.uploaded%</argument>
            <tag name="serializer.normalizer" priority="64"/>
        </service>
    </services>
</container>
