<?xml version="1.0" encoding="UTF-8" ?>

<container
    xmlns="http://symfony.com/schema/dic/services"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd"
>
    <services>
        <service id="sylius_digital_product_plugin.generator.date_path"
                 class="SyliusDigitalProductPlugin\Generator\DatePathGenerator"
        />

        <service id="sylius_digital_product_plugin.generator.storage_file_path"
                 class="SyliusDigitalProductPlugin\Generator\StorageFilePathGenerator"
        >
            <argument type="service" id="sylius_digital_product_plugin.generator.date_path"/>
        </service>

        <service id="SyliusDigitalProductPlugin\Generator\StorageFilePathGeneratorInterface"
                 alias="sylius_digital_product_plugin.generator.storage_file_path"
        />
    </services>
</container>
