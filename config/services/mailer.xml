<?xml version="1.0" encoding="UTF-8" ?>

<container
    xmlns="http://symfony.com/schema/dic/services"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd"
>
    <services>
        <service id="sylius_digital_product_plugin.mailer.digital_download_email_manager"
                 class="SyliusDigitalProductPlugin\Mailer\DigitalDownloadEmailManager"
        >
            <argument type="service" id="sylius.email_sender"/>
            <argument type="service" id="sylius_digital_product_plugin.repository.order_item_file"/>
            <argument type="service" id="router"/>
        </service>

        <service id="SyliusDigitalProductPlugin\Mailer\DigitalDownloadEmailManagerInterface"
                 alias="sylius_digital_product_plugin.mailer.digital_download_email_manager"
        />
    </services>
</container>
