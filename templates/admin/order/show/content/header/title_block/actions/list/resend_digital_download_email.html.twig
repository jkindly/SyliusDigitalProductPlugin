{% set order = hookable_metadata.context.resource %}

{% if order.paymentState == 'paid' %}
    {% set path = path('sylius_digital_product_admin_order_resend_digital_download_email', {'id': order.id, '_csrf_token': csrf_token(order.id)}) %}
    <a class="dropdown-item" href="{{ path }}">
        {{ ux_icon('tabler:send', {'class': 'icon dropdown-item-icon flex-shrink-0'}) }}
        <div class="pe-6">{{ 'sylius_digital_product.ui.resend_digital_download_email'|trans }}</div>
    </a>
{% endif %}
